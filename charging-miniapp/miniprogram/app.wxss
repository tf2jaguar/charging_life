/* ========== 设计系统 Token ========== */
page {
  --primary: #0891B2;
  --primary-light: rgba(8, 145, 178, 0.1);
  --secondary: #22D3EE;
  --cta: #22C55E;
  --cta-light: rgba(34, 197, 94, 0.1);
  --app-bg: #ECFEFF;
  --app-text: #164E63;
  --amber: #F59E0B;
  --amber-dark: #D97706;
  --danger: #EF4444;
  --slate-300: #CBD5E1;
  --slate-400: #94A3B8;
  --slate-500: #64748B;
  --slate-600: #475569;
  --violet: #8B5CF6;
  --violet-light: rgba(139, 92, 246, 0.1);
  --emerald: #10B981;
  --rose: #F43F5E;
  --glass-opacity: 0.85;
  --glass-blur: 10px;
  --card-radius-sm: 24rpx;
  --card-radius-lg: 32rpx;
  --transition: all 0.2s ease;

  background-color: var(--app-bg);
  color: var(--app-text);
  font-size: 28rpx;
  line-height: 1.5;
}

/* ========== Glass Card ========== */
.glass-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: var(--card-radius-sm);
  overflow: hidden;
}

/* ========== 字体 ========== */
.font-mono {
  font-family: 'Menlo', 'Courier New', monospace;
  font-variant-numeric: tabular-nums;
}

/* ========== 通用按钮 ========== */
.btn-primary {
  width: 100%;
  height: 112rpx;
  background: var(--cta);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--card-radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(34, 197, 94, 0.2);
}

.btn-primary::after {
  border: none;
}

/* ========== 通用输入 ========== */
.input-field {
  width: 100%;
  height: 96rpx;
  padding: 0 32rpx;
  background: #fff;
  border: 2rpx solid var(--slate-300);
  border-radius: 16rpx;
  font-size: 30rpx;
  color: var(--app-text);
}

.input-field:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx rgba(8, 145, 178, 0.15);
}

/* ========== 表单分组 ========== */
.form-group {
  padding: 32rpx;
}

.form-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--slate-500);
}

/* ========== 分割线 ========== */
.divider {
  height: 2rpx;
  background: #f1f5f9;
}

/* ========== 安全区域 ========== */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 页面内容区底部留白(给tabBar) ========== */
.page-content {
  padding-bottom: 160rpx;
}

/* ========== Section 标题 ========== */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--app-text);
  margin-bottom: 24rpx;
}

/* ========== 类型标签 ========== */
.tag-fast {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background: rgba(34, 197, 94, 0.1);
  color: var(--cta);
  border-radius: 8rpx;
  font-weight: 500;
}

.tag-slow {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background: var(--primary-light);
  color: var(--primary);
  border-radius: 8rpx;
  font-weight: 500;
}

.tag-super {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background: var(--violet-light);
  color: var(--violet);
  border-radius: 8rpx;
  font-weight: 500;
}

/* ========== 变化指示 ========== */
.change-up-positive {
  color: var(--cta);
  font-size: 24rpx;
}

.change-up-negative {
  color: var(--danger);
  font-size: 24rpx;
}

.change-down-positive {
  color: var(--cta);
  font-size: 24rpx;
}

.change-down-negative {
  color: var(--danger);
  font-size: 24rpx;
}
