.auth-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.auth-popup-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.auth-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 40rpx calc(48rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.auth-popup.show {
  transform: translateY(0);
}

.auth-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 48rpx;
}

.auth-popup-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #164E63;
}

.auth-popup-close {
  font-size: 40rpx;
  color: #94A3B8;
  padding: 8rpx 16rpx;
}

.auth-step-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #64748B;
  display: block;
  margin-bottom: 24rpx;
}

.auth-input-row {
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 32rpx;
}

.auth-input {
  font-size: 30rpx;
  color: #164E63;
}

.auth-next-btn {
  width: 100%;
  height: 96rpx;
  background: #0891B2;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-next-btn::after {
  border: none;
}

.auth-avatar-area {
  margin-bottom: 32rpx;
  display: flex;
  justify-content: center;
}

.auth-avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  overflow: hidden;
}

.auth-avatar-btn::after {
  border: none;
}

.auth-avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.auth-avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.auth-avatar-icon {
  font-size: 48rpx;
}

.auth-avatar-text {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 4rpx;
}

.auth-skip-row {
  text-align: center;
}

.auth-skip {
  font-size: 26rpx;
  color: #94A3B8;
  text-decoration: underline;
}
