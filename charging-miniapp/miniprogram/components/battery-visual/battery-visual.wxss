.battery-visual {
  padding: 0 16rpx;
}

.battery-shell {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.battery-tip {
  width: 16rpx;
  height: 32rpx;
  background: #cbd5e1;
  border-radius: 0 4rpx 4rpx 0;
}

.battery-body {
  flex: 1;
  height: 112rpx;
  background: #f1f5f9;
  border-radius: 16rpx;
  border: 2rpx solid #e2e8f0;
  position: relative;
  overflow: hidden;
}

.battery-empty {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  background: #e2e8f0;
  transition: width 0.5s ease;
}

.battery-charged {
  position: absolute;
  top: 0;
  height: 100%;
  background: linear-gradient(90deg, rgba(34, 197, 94, 0.8), #22C55E);
  transition: all 0.5s ease;
}

.battery-labels {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
}

.label-start {
  position: absolute;
  font-size: 22rpx;
  font-family: 'Menlo', monospace;
  font-weight: 600;
  color: #94A3B8;
}

.label-end {
  position: absolute;
  font-size: 22rpx;
  font-family: 'Menlo', monospace;
  font-weight: 600;
  color: #fff;
  transform: translateX(-50%);
}

.scale-line {
  display: flex;
  margin-left: 24rpx;
  margin-top: 8rpx;
}

.scale-num {
  flex: 1;
  font-size: 20rpx;
  color: #94A3B8;
}

.soc-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 32rpx;
}

.soc-item {
  text-align: center;
}

.soc-label {
  font-size: 22rpx;
  color: #94A3B8;
  display: block;
}

.soc-value {
  font-size: 40rpx;
  font-family: 'Menlo', monospace;
  font-weight: 700;
  display: block;
  margin-top: 4rpx;
}

.soc-value-gray { color: #94A3B8; }
.soc-value-green { color: #22C55E; }

.soc-delta {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  gap: 16rpx;
}

.soc-delta-line {
  flex: 1;
  height: 2rpx;
  background: #e2e8f0;
}

.soc-delta-pill {
  background: rgba(34, 197, 94, 0.1);
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
}

.soc-delta-text {
  font-family: 'Menlo', monospace;
  font-weight: 600;
  font-size: 28rpx;
  color: #22C55E;
}
