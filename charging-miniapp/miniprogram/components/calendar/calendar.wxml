<view class="calendar">
  <!-- 标题行 -->
  <view class="calendar-title-row">
    <view class="calendar-title-left">
      <view class="calendar-title-icon">
        <image class="calendar-icon-img" src="/assets/icons/calendar-blue.svg" mode="aspectFit" />
      </view>
      <text class="calendar-title-text">充电日历</text>
    </view>
    <view class="calendar-title-more" bindtap="onViewMore">
      <text class="calendar-more-text">查看更多</text>
      <text class="calendar-more-arrow">›</text>
    </view>
  </view>

  <!-- 月份导航 -->
  <view class="month-nav">
    <view class="nav-btn" bindtap="onPrevMonth">
      <text class="nav-arrow">‹</text>
    </view>
    <view class="month-info">
      <text class="month-label">{{displayYear}}年{{displayMonth}}月</text>
      <text class="month-stats" wx:if="{{totalCount}}">充电 {{totalCount}} 次</text>
    </view>
    <view class="nav-btn" bindtap="onNextMonth">
      <text class="nav-arrow">›</text>
    </view>
  </view>

  <!-- 星期表头 -->
  <view class="weekday-header">
    <text wx:for="{{weekdays}}" wx:key="*this"
      class="weekday-cell {{index >= 5 ? 'weekday-weekend' : ''}}">
      {{item}}
    </text>
  </view>

  <!-- 日历网格 -->
  <view class="calendar-grid">
    <view wx:for="{{grid}}" wx:key="index"
      class="day-cell {{item.empty ? 'day-empty' : ''}} {{item.isToday && item.isCharged ? 'day-today-charged' : ''}} {{item.isToday && !item.isCharged ? 'day-today' : ''}} {{item.isCharged && !item.isToday ? 'day-charged' : ''}} {{!item.isCharged && !item.isToday && !item.empty ? 'day-normal' : ''}}">
      <block wx:if="{{!item.empty}}">
        <text class="day-num">{{item.day}}</text>
        <text wx:if="{{item.isCharged}}" class="day-bolt">⚡</text>
      </block>
    </view>
  </view>

  <!-- 底部图例 -->
  <view class="calendar-legend">
    <text class="legend-summary">合计 {{totalKwh}} kWh</text>
    <view class="legend-items">
      <view class="legend-item">
        <view class="legend-box legend-box-charged">
          <view class="legend-box-dot legend-dot-charged"></view>
        </view>
        <text class="legend-text">已充电</text>
      </view>
      <view class="legend-item">
        <view class="legend-box legend-box-normal"></view>
        <text class="legend-text">未充电</text>
      </view>
      <view class="legend-item">
        <view class="legend-box legend-box-today">
          <view class="legend-box-dot legend-dot-today"></view>
        </view>
        <text class="legend-text">今天</text>
      </view>
    </view>
  </view>
</view>
