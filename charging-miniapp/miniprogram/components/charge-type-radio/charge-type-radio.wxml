<view class="type-radio">
  <view
    wx:for="{{types}}"
    wx:key="key"
    class="type-card {{value === item.key ? 'type-card-active' : ''}}"
    style="{{value === item.key ? 'border-color:' + item.borderActive + ';background:' + item.bg : ''}}"
    data-key="{{item.key}}"
    bindtap="onSelect"
  >
    <view class="type-icon">
      <image class="flashlight-icon" src="{{item.icon}}" mode="aspectFit" />
    </view>
    <text class="type-label">{{item.label}}</text>
  </view>
</view>
