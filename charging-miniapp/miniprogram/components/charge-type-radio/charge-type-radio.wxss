.type-radio {
  display: flex;
  gap: 16rpx;
}

.type-card {
  flex: 1;
  height: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border: 4rpx solid #e2e8f0;
  border-radius: var(--card-radius-sm, 24rpx);
  transition: all 0.2s ease;
}

.type-card-active {
  border-width: 4rpx;
}

.type-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.flashlight-icon {
  width: 48rpx;
  height: 48rpx;
}

.type-label {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--app-text, #164E63);
}
