<navigator url="/pages/record-detail/record-detail?id={{record._id}}" class="record-card" hover-class="record-card-active">
  <view class="record-header">
    <view class="record-icon {{record.chargeType === 'super' ? 'record-icon-super' : record.chargeType === 'slow' ? 'record-icon-slow' : 'record-icon-fast'}}">
      <image class="flashlight-icon" src="{{record.chargeType === 'super' ? '/assets/icons/flashlight-puper.svg' : record.chargeType === 'slow' ? '/assets/icons/flashlight-green.svg' : '/assets/icons/flashlight-blue.svg'}}" mode="aspectFit" />
    </view>
    <view class="record-info">
      <view class="record-name-row">
        <text class="record-name">{{record.stationName}}</text>
        <text class="{{record.chargeType === 'fast' ? 'tag-fast' : record.chargeType === 'super' ? 'tag-super' : 'tag-slow'}}">
          {{record.chargeType === 'super' ? '超充' : record.chargeType === 'fast' ? '快充' : '慢充'}}
        </text>
      </view>
      <text class="record-time">{{record.timeText}}</text>
    </view>
    <view class="record-cost">
      <text class="record-fee font-mono">¥{{record.cost}}</text>
    </view>
  </view>
  <view class="record-detail-row" wx:if="{{record.startSOC !== undefined}}">
    <view class="detail-item">
      <text class="detail-label">充电量</text>
      <text class="detail-value font-mono">{{record.chargeKwh}} kWh</text>
    </view>
    <view class="detail-item">
      <text class="detail-label">电量</text>
      <text class="detail-value font-mono">{{record.startSOC}}% → {{record.endSOC}}%</text>
    </view>
    <view class="detail-item detail-item-right">
      <text class="detail-label">平均价格</text>
      <text class="detail-value detail-value-price font-mono">{{record.unitPrice ? record.unitPrice + ' 元/度' : '--'}}</text>
    </view>
  </view>
  <view class="record-efficiency">
    <view class="efficiency-item">
      <text class="efficiency-label">{{record.chargeLoss > 5 ? '电池性能下降' : '充电损耗'}}</text>
      <text class="efficiency-value font-mono {{record.chargeLoss > 5 ? 'efficiency-warn' : 'efficiency-good'}}">{{record.chargeLoss ? record.chargeLoss + '%' : '--'}}</text>
    </view>
    <view class="efficiency-item">
      <text class="efficiency-label">平均功率</text>
      <text class="efficiency-value font-mono">{{record.avgPower ? record.avgPower + ' kW' : '--'}}</text>
    </view>
  </view>
</navigator>
