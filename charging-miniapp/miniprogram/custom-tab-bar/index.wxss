.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: #fff;
  border-top: 1rpx solid #e2e8f0;
}

.tab-bar-inner {
  display: flex;
  align-items: flex-end;
  height: 110rpx;
  padding: 0 16rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: 8rpx;
  min-height: 88rpx;
}

.tab-item-center {
  position: relative;
  margin-top: -40rpx;
}

.tab-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 4rpx;
  line-height: 1.2;
}

.tab-text-active {
  color: #0891B2;
  font-weight: 500;
}

/* CTA中间按钮 */
.center-btn {
  width: 112rpx;
  height: 112rpx;
  background: #22C55E;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(34, 197, 94, 0.3);
}

.center-btn-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.center-icon {
  width: 48rpx;
  height: 48rpx;
}

.safe-bottom {
  background: #fff;
}
