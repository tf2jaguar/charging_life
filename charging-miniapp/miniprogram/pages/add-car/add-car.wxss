.page {
  padding: 32rpx;
  background: var(--app-bg, #ECFEFF);
}

.page-content {
  padding-bottom: 200rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-icon {
  font-size: 28rpx;
}

.picker-field {
  display: flex;
  align-items: center;
  color: var(--app-text, #164E63);
}

.input-disabled {
  opacity: 0.5;
}

.placeholder {
  color: #cbd5e1;
}

.hint-text {
  font-size: 22rpx;
  color: #cbd5e1;
  margin-top: 16rpx;
  display: block;
}

.default-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.default-text {
  font-size: 30rpx;
  color: var(--app-text, #164E63);
}

.submit-area {
  margin-top: 48rpx;
}

.feedback-box {
  margin-top: 32rpx;
  padding: 32rpx;
  background: rgba(8, 145, 178, 0.05);
  border-radius: 20rpx;
}

.feedback-text {
  font-size: 28rpx;
  color: #64748B;
}

.feedback-link {
  color: #0891B2;
  font-weight: 500;
}
