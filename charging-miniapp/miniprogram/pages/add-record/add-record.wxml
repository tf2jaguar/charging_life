<view class="page page-content">
  <form bindsubmit="onSubmit">
    <!-- 选择车辆 -->
    <view class="form-group glass-card">
      <view class="form-label">
        <text class="form-icon">🚗</text>
        <text>选择车辆</text>
      </view>
      <picker range="{{vehicles}}" range-key="displayName" value="{{vehicleIndex}}" bindchange="onVehicleChange">
        <view class="input-field picker-field">
          <text wx:if="{{vehicles.length}}">{{vehicles[vehicleIndex].brand}} {{vehicles[vehicleIndex].model}}</text>
          <text wx:else class="placeholder">请先添加车辆</text>
        </view>
      </picker>
    </view>

    <!-- 充电站 -->
    <view class="form-group glass-card">
      <view class="form-label">
        <text class="form-icon">📍</text>
        <text>充电站名称</text>
      </view>
      <input class="input-field" placeholder="输入或选择充电站" value="{{stationName}}" bindinput="onStationInput" />
      <view class="form-label" style="margin-top: 32rpx;">
        <text class="form-icon">⚡</text>
        <text>充电类型</text>
      </view>
      <charge-type-radio value="{{chargeType}}" bind:change="onChargeTypeChange" />
    </view>

    <!-- 充电时间 -->
    <view class="form-group glass-card">
      <view class="form-label">
        <text class="form-icon">🕐</text>
        <text>充电时间</text>
      </view>
      <view class="time-row">
        <view class="time-field">
          <text class="time-label">开始时间</text>
          <picker mode="date" value="{{startTime}}" bindchange="onStartTimeChange">
            <view class="input-field">{{startTime || '选择时间'}}</view>
          </picker>
        </view>
        <view class="time-field">
          <text class="time-label">结束时间</text>
          <picker mode="date" value="{{endTime}}" bindchange="onEndTimeChange">
            <view class="input-field">{{endTime || '选择时间'}}</view>
          </picker>
        </view>
      </view>
      <view class="computed-box">
        <text class="computed-text">充电时长: <text class="font-mono computed-value">{{durationText}}</text></text>
      </view>
    </view>

    <!-- 充电量与费用 -->
    <view class="form-group glass-card">
      <view class="form-label">
        <text class="form-icon">📊</text>
        <text>充电量与费用</text>
      </view>
      <view class="time-row">
        <view class="time-field">
          <text class="time-label">充电量</text>
          <view class="input-with-suffix">
            <input class="input-field" type="digit" placeholder="0.00" value="{{chargeKwh}}" bindinput="onChargeKwhInput" />
            <text class="input-suffix">kWh</text>
          </view>
        </view>
        <view class="time-field">
          <text class="time-label">充电费用</text>
          <view class="input-with-prefix">
            <text class="input-prefix">¥</text>
            <input class="input-field input-with-left-pad" type="digit" placeholder="0.00" value="{{cost}}" bindinput="onCostInput" />
          </view>
        </view>
      </view>
      <view class="computed-row">
        <text class="computed-text">单价: <text class="font-mono computed-value-amber">{{unitPriceText}}</text></text>
        <text class="computed-text">平均功率: <text class="font-mono computed-value">{{avgPowerText}}</text></text>
      </view>
    </view>

    <!-- 电量信息 -->
    <view class="form-group glass-card">
      <view class="form-label">
        <text class="form-icon">🔋</text>
        <text>电量信息</text>
      </view>
      <view class="slider-group">
        <view class="slider-header">
          <text class="slider-label">起始电量</text>
          <text class="slider-value font-mono">{{startSOC}}%</text>
        </view>
        <slider min="0" max="100" value="{{startSOC}}" activeColor="#0891B2" bindchange="onStartSOCChange" />
      </view>
      <view class="slider-group">
        <view class="slider-header">
          <text class="slider-label">结束电量</text>
          <text class="slider-value font-mono" style="color: #22C55E;">{{endSOC}}%</text>
        </view>
        <slider min="0" max="100" value="{{endSOC}}" activeColor="#22C55E" bindchange="onEndSOCChange" />
      </view>
      <view class="computed-box computed-box-green">
        <text class="computed-text">电量提升: <text class="font-mono" style="color: #22C55E; font-weight: 600;">+{{socDelta}}%</text></text>
      </view>
    </view>

    <!-- 里程 -->
    <view class="form-group glass-card">
      <view class="form-label">
        <text class="form-icon">🗺</text>
        <text>充电完成时仪表盘总里程</text>
      </view>
      <view class="input-with-suffix">
        <input class="input-field" type="digit" placeholder="输入充电完成时的总里程" value="{{mileage}}" bindinput="onMileageInput" />
        <text class="input-suffix">km</text>
      </view>
      <text class="hint-text">用于计算百公里电耗和成本</text>
    </view>

    <!-- 备注 -->
    <view class="form-group glass-card">
      <view class="form-label">
        <text class="form-icon">💬</text>
        <text>备注</text>
      </view>
      <textarea class="textarea-field" placeholder="添加备注信息..." value="{{remark}}" bindinput="onRemarkInput" />
    </view>

    <!-- 提交 -->
    <view class="submit-area">
      <button class="btn-primary" bindtap="onSubmit" disabled="{{submitting}}">
        ✓ 保存记录
      </button>
    </view>
  </form>
</view>
