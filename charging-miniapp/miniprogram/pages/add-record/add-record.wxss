.page {
  padding: 32rpx;
  background: var(--app-bg, #ECFEFF);
}

.page-content {
  padding-bottom: 200rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-icon {
  font-size: 28rpx;
}

.form-icon-img {
  width: 28rpx;
  height: 28rpx;
}

.required-tag {
  font-size: 20rpx;
  color: #EF4444;
  background: rgba(239, 68, 68, 0.08);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  margin-left: 8rpx;
}

.optional-tag {
  font-size: 20rpx;
  color: #94A3B8;
  background: rgba(148, 163, 184, 0.08);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  margin-left: 8rpx;
}

.time-row {
  display: flex;
  gap: 24rpx;
}

.time-field {
  flex: 1;
}

.time-label {
  font-size: 22rpx;
  color: #94A3B8;
  margin-bottom: 12rpx;
  display: block;
}

.picker-field {
  display: flex;
  align-items: center;
  color: var(--app-text, #164E63);
}

.placeholder {
  color: #cbd5e1;
}

.computed-box {
  margin-top: 24rpx;
  padding: 24rpx;
  background: rgba(8, 145, 178, 0.05);
  border-radius: 16rpx;
}

.computed-box-green {
  background: rgba(34, 197, 94, 0.05);
}

.computed-text {
  font-size: 28rpx;
  color: #64748B;
}

.computed-value {
  font-weight: 600;
  color: #0891B2;
}

.computed-value-amber {
  font-weight: 600;
  color: #D97706;
}

.computed-row {
  margin-top: 24rpx;
  padding: 24rpx;
  background: rgba(245, 158, 11, 0.05);
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
}

.input-with-suffix,
.input-with-prefix {
  position: relative;
}

.input-suffix {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: #94A3B8;
  z-index: 1;
}

.input-prefix {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #94A3B8;
  z-index: 1;
}

.input-with-left-pad {
  padding-left: 48rpx !important;
}

.textarea-field {
  width: 100%;
  padding: 24rpx;
  background: #fff;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--app-text, #164E63);
  min-height: 180rpx;
}

.submit-area {
  margin-top: 48rpx;
  padding-bottom: 32rpx;
}
