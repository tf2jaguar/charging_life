.page {
  background: var(--app-bg, #ECFEFF);
  min-height: 100vh;
  padding: 32rpx;
}

.period-switch {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
  justify-content: flex-end;
}

.period-btn {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  background: #f1f5f9;
  color: #64748B;
  border-radius: 12rpx;
}

.period-active {
  background: #0891B2;
  color: #fff;
}

.card-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #64748B;
  display: block;
  margin-bottom: 32rpx;
}

/* 核心指标 */
.core-stats {
  margin-bottom: 32rpx;
  padding: 32rpx;
}

.core-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32rpx;
}

.core-item {
  text-align: center;
}

.core-item-border {
  border-left: 2rpx solid #f1f5f9;
  border-right: 2rpx solid #f1f5f9;
}

.core-value {
  font-size: 48rpx;
  font-weight: 700;
  display: block;
}

.core-label {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 8rpx;
  display: block;
}

/* 趋势图 */
.trend-card {
  margin-bottom: 32rpx;
  padding: 32rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.legend-row {
  display: flex;
  gap: 24rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 6rpx;
}

.legend-text {
  font-size: 22rpx;
  color: #64748B;
}

.legend-value {
  font-weight: 600;
  font-size: 26rpx;
}

.legend-pct {
  font-size: 22rpx;
  color: #94A3B8;
}

.bar-chart {
  height: 320rpx;
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
}

.bar-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.bar-pair {
  width: 100%;
  height: 256rpx;
  display: flex;
  gap: 4rpx;
  align-items: flex-end;
}

.bar {
  flex: 1;
  border-radius: 8rpx 8rpx 0 0;
  min-height: 8rpx;
}

.bar-kwh {
  background: linear-gradient(180deg, #DD847E, #E8A8A3);
}

.bar-cost {
  background: linear-gradient(180deg, #A7D398, #C2E4B8);
}

.bar-label {
  font-size: 20rpx;
  color: #94A3B8;
}

/* 时段分布 */
.time-dist {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 32rpx;
}

.time-slot {
  text-align: center;
}

.time-bar-bg {
  height: 192rpx;
  background: rgba(116, 163, 212, 0.1);
  border-radius: 12rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 16rpx;
}

.time-bar {
  width: 100%;
  border-radius: 8rpx;
  min-height: 8rpx;
}

.time-label {
  font-size: 22rpx;
  color: #64748B;
  margin-top: 16rpx;
  display: block;
}

.time-pct {
  font-size: 22rpx;
  font-weight: 600;
  display: block;
}

/* 类型占比 */
.type-dist {
  display: flex;
  padding: 32rpx;
  gap: 48rpx;
  align-items: center;
}

.pie-area {
  width: 256rpx;
  height: 256rpx;
  border-radius: 50%;
  background: conic-gradient(
    #164E63 0deg,
    #164E63 61deg,
    #0891B2 61deg,
    #0891B2 241deg,
    #22C55E 241deg,
    #22C55E 360deg
  );
  position: relative;
  flex-shrink: 0;
}

.pie-center {
  position: absolute;
  inset: 25%;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.pie-total {
  font-size: 36rpx;
  font-weight: 700;
}

.pie-label {
  font-size: 22rpx;
  color: #94A3B8;
}

.type-legend {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.type-legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 效率 */
.efficiency-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  padding: 32rpx;
}

.eff-box {
  text-align: center;
  padding: 24rpx;
  border-radius: 20rpx;
}

.eff-value {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.eff-label {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 8rpx;
  display: block;
}

/* 充电站排行 */
.station-rank {
  padding: 32rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.rank-item:last-child {
  margin-bottom: 0;
}

.rank-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.rank-1 {
  background: rgba(245, 158, 11, 0.1);
  color: #D97706;
}

.rank-2 {
  background: #f1f5f9;
  color: #64748B;
}

.rank-3 {
  background: rgba(8, 145, 178, 0.05);
  color: #0891B2;
}

.rank-info {
  flex: 1;
  min-width: 0;
}

.rank-name {
  font-weight: 500;
  font-size: 28rpx;
  display: block;
}

.rank-detail {
  font-size: 22rpx;
  color: #94A3B8;
}

.rank-cost {
  font-size: 28rpx;
  color: #64748B;
}
