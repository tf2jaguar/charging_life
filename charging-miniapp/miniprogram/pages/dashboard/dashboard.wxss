.page {
  min-height: 100vh;
  background: var(--app-bg, #ECFEFF);
  padding-bottom: 180rpx;
}

.status-bar {
  background: var(--primary, #0891B2);
}

/* Primary头部 */
.header-primary {
  background: var(--primary, #0891B2);
  color: #fff;
  padding: 32rpx 32rpx 64rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.greeting-area {
  display: flex;
  flex-direction: column;
}

.greeting-text {
  font-size: 26rpx;
  opacity: 0.8;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
}

.header-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon {
  font-size: 36rpx;
}

/* 车辆卡 */
.vehicle-card {
  margin-top: 16rpx;
}

.vehicle-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.vehicle-icon {
  width: 96rpx;
  height: 96rpx;
  background: rgba(8, 145, 178, 0.1);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.vehicle-info {
  flex: 1;
  min-width: 0;
}

.vehicle-name {
  font-weight: 600;
  font-size: 30rpx;
  color: var(--app-text, #164E63);
  display: block;
}

.vehicle-trim {
  font-size: 26rpx;
  color: #64748B;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.vehicle-charge-info {
  text-align: right;
  flex-shrink: 0;
}

.vehicle-charge-kwh {
  display: flex;
  align-items: center;
  gap: 6rpx;
  justify-content: flex-end;
}

.vehicle-charge-icon {
  font-size: 24rpx;
  color: #22C55E;
}

.vehicle-charge-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #164E63;
}

.vehicle-charge-time {
  font-size: 24rpx;
  color: #94A3B8;
  display: block;
  margin-top: 4rpx;
}

/* 快捷入口 */
.quick-entry {
  margin: -32rpx 32rpx 0;
  position: relative;
  z-index: 10;
  padding: 32rpx;
}

.entry-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
}

.entry-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.entry-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.entry-icon-cta { 
  background: rgba(106, 245, 141, 0.193);
}

.entry-icon-primary {
  background: rgba(8, 145, 178, 0.1);
}

.entry-icon-amber {
  background: rgba(245, 159, 11, 0.258);
}

.entry-icon-violet {
  background: rgba(138, 92, 246, 0.263);
}

.entry-text {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--app-text, #164E63);
}

/* 概览 */
.overview-section {
  padding: 32rpx;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

/* 日历 */
.calendar-section {
  padding: 0 32rpx;
  margin-top: 16rpx;
}

.calendar-card {
  padding: 0;
  overflow: hidden;
}

/* 最近充电 */
.recent-section {
  padding: 32rpx;
  margin-top: 16rpx;
}

.recent-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.recent-more {
  font-size: 28rpx;
  color: var(--primary, #0891B2);
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.recent-item {
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.recent-item-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.recent-item-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.icon-fast {
  background: rgba(34, 197, 94, 0.1);
  color: #22C55E;
}

.icon-slow {
  background: rgba(8, 145, 178, 0.1);
  color: #0891B2;
}

.recent-item-info {
  display: flex;
  flex-direction: column;
}

.recent-item-name {
  font-weight: 500;
  font-size: 30rpx;
  color: var(--app-text, #164E63);
}

.recent-item-time {
  font-size: 24rpx;
  color: #94A3B8;
}

.recent-item-right {
  text-align: right;
}

.recent-item-kwh {
  font-weight: 600;
  font-size: 30rpx;
  color: var(--app-text, #164E63);
  display: block;
}

.recent-item-cost {
  font-size: 24rpx;
  color: #94A3B8;
}
