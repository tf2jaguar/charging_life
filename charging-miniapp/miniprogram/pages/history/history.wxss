.page {
  background: var(--app-bg, #ECFEFF);
  min-height: 100vh;
}

.filter-bar {
  background: #fff;
  padding: 16rpx 32rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-pill {
  display: inline-block;
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 100rpx;
  margin-right: 16rpx;
  color: #64748B;
  background: #f1f5f9;
}

.filter-active {
  background: #0891B2;
  color: #fff;
}

.overview-card {
  margin: 32rpx;
}

.overview-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.overview-label {
  font-size: 26rpx;
  color: #64748B;
  display: block;
}

.overview-value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--app-text, #164E63);
  margin-top: 8rpx;
  display: block;
}

.record-list {
  padding: 0 32rpx;
}

.date-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #64748B;
  padding: 16rpx 0;
  display: block;
}

.record-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.load-more {
  padding: 48rpx;
  text-align: center;
}

.load-more-text {
  font-size: 28rpx;
  color: #0891B2;
  font-weight: 500;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #64748B;
  font-weight: 500;
}

.empty-hint {
  font-size: 26rpx;
  color: #94A3B8;
  margin-top: 12rpx;
}
