<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>

  <!-- Primary头部 -->
  <view class="header-primary">
    <!-- 已登录 -->
    <view class="user-area" wx:if="{{isLoggedIn}}">
      <view class="avatar">
        <image wx:if="{{userInfo.avatarUrl}}" class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
        <text wx:else class="avatar-icon">👤</text>
      </view>
      <view class="user-info">
        <text class="user-name">{{nickName}}</text>
      </view>
    </view>

    <!-- 未登录 - 初始状态 -->
    <view class="user-area" wx:if="{{!isLoggedIn && loginStep === 0}}">
      <view class="avatar">
        <text class="avatar-icon">👤</text>
      </view>
      <view class="user-info">
        <text class="user-name">未登录</text>
        <text class="login-hint">点击登录获取专属数据</text>
      </view>
      <button class="login-btn" bindtap="onStartLogin">登录</button>
    </view>

    <!-- 未登录 - 第一步：填昵称 -->
    <view class="login-form" wx:if="{{!isLoggedIn && loginStep === 1}}">
      <text class="login-step-title">第一步：设置昵称</text>
      <view class="login-input-row">
        <input
          class="login-input"
          type="nickname"
          placeholder="请输入微信昵称"
          value="{{tempNickName}}"
          bindinput="onNickNameInput"
          bindconfirm="onNickNameConfirm"
        />
      </view>
      <button class="login-next-btn" bindtap="onNickNameConfirm">下一步</button>
    </view>

    <!-- 未登录 - 第二步：选头像 -->
    <view class="login-form" wx:if="{{!isLoggedIn && loginStep === 2}}">
      <text class="login-step-title">第二步：选择头像</text>
      <view class="login-avatar-area">
        <button class="login-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image wx:if="{{tempAvatarUrl}}" class="login-avatar-preview" src="{{tempAvatarUrl}}" mode="aspectFill" />
          <view wx:else class="login-avatar-placeholder">
            <text class="login-avatar-icon">📷</text>
            <text class="login-avatar-text">选择头像</text>
          </view>
        </button>
      </view>
      <view class="login-skip-row">
        <text class="login-skip" bindtap="onSkipAvatar">跳过，暂不设置头像</text>
      </view>
    </view>

    <!-- 统计卡 -->
    <view class="stats-card glass-card">
      <view class="stats-grid">
        <view class="stats-item">
          <text class="stats-value font-mono">{{totalKwh}}</text>
          <text class="stats-label">累计充电(kWh)</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-item">
          <text class="stats-value font-mono">{{totalCost}}</text>
          <text class="stats-label">累计费用</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-item">
          <text class="stats-value font-mono">{{totalDays}}</text>
          <text class="stats-label">充电天数</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 我的车辆 -->
  <view class="section glass-card">
    <view class="section-header">
      <text class="section-title">我的车辆</text>
      <text class="section-link" bindtap="goToAddCar">添加</text>
    </view>
    <view class="vehicle-list">
      <view wx:for="{{vehicles}}" wx:key="_id" class="vehicle-item">
        <view class="vehicle-icon-box {{item.isDefault ? 'vehicle-icon-default' : 'vehicle-icon-other'}}">🚗</view>
        <view class="vehicle-text">
          <text class="vehicle-name">{{item.brand}} {{item.model}}</text>
          <text class="vehicle-trim">{{item.trim}} · {{item.batteryCapacity}}kWh</text>
        </view>
        <text wx:if="{{item.isDefault}}" class="default-tag">默认</text>
      </view>
      <view wx:if="{{!vehicles.length}}" class="empty-vehicle" bindtap="goToAddCar">
        <text class="empty-text">+ 添加车辆</text>
      </view>
    </view>
  </view>

  <!-- 数据管理 -->
  <view class="section glass-card">
    <view class="section-header">
      <text class="section-title">数据管理</text>
    </view>
    <view class="menu-list">
      <view class="menu-item">
        <view class="menu-left">
          <view class="menu-icon menu-icon-violet">📄</view>
          <text class="menu-text">导出数据</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onImportData">
        <view class="menu-left">
          <view class="menu-icon menu-icon-primary">📥</view>
          <view>
            <text class="menu-text">数据导入</text>
            <text class="menu-sub">从 JSON 文件导入充电记录和车辆</text>
          </view>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 设置 -->
  <view class="section glass-card">
    <view class="section-header">
      <text class="section-title">设置</text>
    </view>
    <view class="menu-list">
      <view class="menu-item">
        <view class="menu-left">
          <view class="menu-icon menu-icon-amber">🔔</view>
          <text class="menu-text">通知提醒</text>
        </view>
        <switch checked="{{settings.notification}}" bindchange="onNotificationToggle" color="#22C55E" />
      </view>
      <view class="menu-item">
        <view class="menu-left">
          <view class="menu-icon menu-icon-cta">💰</view>
          <view>
            <text class="menu-text">费用预算提醒</text>
            <text class="menu-sub">每月 ¥{{settings.budgetLimit}}</text>
          </view>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item">
        <view class="menu-left">
          <view class="menu-icon menu-icon-slate">🌙</view>
          <text class="menu-text">主题设置</text>
        </view>
        <view class="menu-right-text">
          <text class="menu-sub">浅色</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
      <view class="menu-item">
        <view class="menu-left">
          <view class="menu-icon menu-icon-primary">ℹ️</view>
          <text class="menu-text">关于</text>
        </view>
        <view class="menu-right-text">
          <text class="menu-sub">v1.0.0</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出 -->
  <view class="logout-area" wx:if="{{isLoggedIn}}">
    <text class="logout-btn" bindtap="onLogout">退出登录</text>
  </view>
</view>
