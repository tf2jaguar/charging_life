.page {
  background: var(--app-bg, #ECFEFF);
  min-height: 100vh;
  padding-bottom: 180rpx;
}

.status-bar {
  background: var(--primary, #0891B2);
}

.header-primary {
  background: var(--primary, #0891B2);
  color: #fff;
  padding: 48rpx 32rpx 64rpx;
}

.user-area {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 64rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
}

.login-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-top: 4rpx;
}

.login-btn {
  margin-left: auto;
  padding: 12rpx 40rpx;
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  font-size: 28rpx;
  border-radius: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  line-height: 1.4;
}

.login-btn::after {
  border: none;
}

.stats-card {
  margin-top: 16rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr auto 1fr auto 1fr;
  align-items: center;
  text-align: center;
}

.stats-item {
  padding: 16rpx;
}

.stats-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--app-text, #164E63);
  display: block;
}

.stats-label {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 8rpx;
  display: block;
}

.stats-divider {
  width: 2rpx;
  height: 64rpx;
  background: #e2e8f0;
}

/* Sections */
.section {
  margin: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.section-title {
  font-weight: 600;
  font-size: 30rpx;
  color: var(--app-text, #164E63);
}

.section-link {
  font-size: 28rpx;
  color: #0891B2;
}

/* 车辆列表 */
.vehicle-list {
  padding: 0;
}

.vehicle-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.vehicle-item:last-child {
  border-bottom: none;
}

.vehicle-icon-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.vehicle-icon-default {
  background: rgba(8, 145, 178, 0.1);
}

.vehicle-icon-other {
  background: rgba(34, 211, 238, 0.1);
}

.vehicle-text {
  flex: 1;
  min-width: 0;
}

.vehicle-name {
  font-weight: 500;
  font-size: 30rpx;
  display: block;
}

.vehicle-trim {
  font-size: 26rpx;
  color: #94A3B8;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.default-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  background: rgba(34, 197, 94, 0.1);
  color: #22C55E;
  border-radius: 8rpx;
}

.empty-vehicle {
  padding: 32rpx;
  text-align: center;
}

.empty-text {
  color: #0891B2;
  font-size: 28rpx;
}

/* 菜单列表 */
.menu-list {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.menu-icon-violet { background: rgba(139, 92, 246, 0.1); }
.menu-icon-primary { background: rgba(8, 145, 178, 0.1); }
.menu-icon-amber { background: rgba(245, 158, 11, 0.1); }
.menu-icon-cta { background: rgba(34, 197, 94, 0.1); }
.menu-icon-slate { background: #f1f5f9; }

.menu-text {
  font-size: 30rpx;
  color: var(--app-text, #164E63);
}

.menu-sub {
  font-size: 24rpx;
  color: #94A3B8;
  display: block;
  margin-top: 4rpx;
}

.menu-arrow {
  font-size: 36rpx;
  color: #94A3B8;
  margin-left: 8rpx;
}

.menu-right-text {
  display: flex;
  align-items: center;
}

/* 退出 */
.logout-area {
  margin: 32rpx;
  text-align: center;
}

.logout-btn {
  width: 100%;
  padding: 32rpx;
  color: #EF4444;
  font-size: 30rpx;
  font-weight: 500;
  display: block;
}
