<view class="page page-content" wx:if="{{record}}">
  <!-- 车辆信息 -->
  <view class="form-group glass-card" wx:if="{{record.vehicleInfo}}">
    <view class="form-label">
      <image class="form-icon-img" src="/assets/icons/car-blue.svg" mode="aspectFit" />
      <text>车辆信息</text>
    </view>
    <view class="vehicle-info-box">
      <text class="vehicle-name-text">{{record.vehicleInfo.brand}} {{record.vehicleInfo.model}}</text>
      <text class="vehicle-trim-text">{{record.vehicleInfo.trim}} · {{record.vehicleInfo.batteryCapacity}}kWh</text>
    </view>
  </view>

  <!-- 充电站 -->
  <view class="form-group glass-card">
    <view class="form-label">
      <image class="form-icon-img" src="/assets/icons/map-blue.svg" mode="aspectFit" />
      <text>充电站名称</text>
      <text class="optional-tag">选填</text>
    </view>
    <!-- 查看 -->
    <view wx:if="{{!isEditMode}}" class="view-field">
      <view class="station-row">
        <text class="station-name">{{record.stationName}}</text>
        <text class="{{record.chargeType === 'fast' ? 'tag-fast' : record.chargeType === 'super' ? 'tag-super' : 'tag-slow'}}">
          {{record.chargeType === 'super' ? '超充' : record.chargeType === 'fast' ? '快充' : '慢充'}}
        </text>
      </view>
    </view>
    <!-- 编辑 -->
    <view wx:else class="edit-field">
      <input class="input-field" placeholder="输入或选择充电站" value="{{editStationName}}" bindinput="onEditStationInput" />
      <view class="form-label" style="margin-top: 24rpx;">
        <image class="form-icon-img" src="/assets/icons/flashlight-blue.svg" mode="aspectFit" />
        <text>充电类型</text>
      </view>
      <charge-type-radio value="{{editChargeType}}" bind:change="onEditChargeTypeChange" />
    </view>
  </view>

  <!-- 充电时间 -->
  <view class="form-group glass-card">
    <view class="form-label">
      <image class="form-icon-img" src="/assets/icons/clock-active.svg" mode="aspectFit" />
      <text>充电时间</text>
      <text wx:if="{{isEditMode}}" class="required-tag">必填</text>
    </view>
    <view wx:if="{{!isEditMode}}" class="view-field">
      <view class="time-info">
        <view class="time-left">
          <text class="time-range">{{record.startTimeText}}</text>
          <text class="time-date">{{record.dateText}}</text>
        </view>
        <view class="time-right">
          <text class="duration-text font-mono">{{record.durationText}}</text>
          <text class="duration-label">充电时长</text>
        </view>
      </view>
    </view>
    <view wx:else class="edit-field">
      <view class="time-row">
        <view class="time-field">
          <text class="time-label">开始日期</text>
          <picker mode="date" value="{{editStartDate}}" bindchange="onEditStartDateChange">
            <view class="input-field picker-field">
              <text>{{editStartDate || '选择日期'}}</text>
            </view>
          </picker>
        </view>
        <view class="time-field">
          <text class="time-label">开始时间</text>
          <picker mode="time" value="{{editStartTime}}" bindchange="onEditStartTimeChange">
            <view class="input-field picker-field">
              <text>{{editStartTime || '选择时间'}}</text>
            </view>
          </picker>
        </view>
      </view>
      <view class="time-row" style="margin-top: 16rpx;">
        <view class="time-field">
          <text class="time-label">结束日期</text>
          <picker mode="date" value="{{editEndDate}}" bindchange="onEditEndDateChange">
            <view class="input-field picker-field">
              <text>{{editEndDate || '选择日期'}}</text>
            </view>
          </picker>
        </view>
        <view class="time-field">
          <text class="time-label">结束时间</text>
          <picker mode="time" value="{{editEndTime}}" bindchange="onEditEndTimeChange">
            <view class="input-field picker-field">
              <text>{{editEndTime || '选择时间'}}</text>
            </view>
          </picker>
        </view>
      </view>
      <view class="computed-box">
        <text class="computed-text">充电时长: <text class="font-mono computed-value">{{editDurationText}}</text></text>
      </view>
    </view>
  </view>

  <!-- 电量可视化 -->
  <view class="form-group glass-card">
    <view class="form-label">
      <image class="form-icon-img" src="/assets/icons/battery-blue.svg" mode="aspectFit" />
      <text>电量信息</text>
      <text class="optional-tag">选填</text>
    </view>
    <battery-visual
      wx:if="{{!isEditMode}}"
      startSOC="{{record.startSOC}}"
      endSOC="{{record.endSOC}}"
    />
    <!-- 编辑模式slider -->
    <view wx:else class="edit-field">
      <view class="time-row">
        <view class="time-field">
          <text class="time-label">起始电量</text>
          <view class="input-with-suffix">
            <input class="input-field" type="number" placeholder="0" value="{{editStartSOC}}" bindinput="onEditStartSOCInput" />
            <text class="input-suffix">%</text>
          </view>
        </view>
        <view class="time-field">
          <text class="time-label">结束电量</text>
          <view class="input-with-suffix">
            <input class="input-field" type="number" placeholder="0" value="{{editEndSOC}}" bindinput="onEditEndSOCInput" />
            <text class="input-suffix">%</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 充电量与费用 -->
  <view class="form-group glass-card">
    <view class="form-label">
      <image class="form-icon-img" src="/assets/icons/bill-blue.svg" mode="aspectFit" />
      <text>充电量与费用</text>
      <text wx:if="{{isEditMode}}" class="required-tag">必填</text>
    </view>
    <view wx:if="{{!isEditMode}}" class="view-field">
      <view class="cost-grid">
        <view class="cost-item cost-item-primary">
          <text class="cost-label">充电量</text>
          <text class="cost-value font-mono">{{record.chargeKwh}} kWh</text>
        </view>
        <view class="cost-item cost-item-amber">
          <text class="cost-label">费用</text>
          <text class="cost-value font-mono">¥{{record.cost}}</text>
        </view>
        <view class="cost-item cost-item-cta">
          <text class="cost-label">单价</text>
          <text class="cost-value font-mono">¥{{record.unitPrice}}/kWh</text>
        </view>
      </view>
    </view>
    <view wx:else class="edit-field">
      <view class="time-row">
        <view class="time-field">
          <text class="time-label">充电量</text>
          <view class="input-with-suffix">
            <input class="input-field" type="digit" placeholder="0.00" value="{{editChargeKwh}}" bindinput="onEditChargeKwhInput" />
            <text class="input-suffix">kWh</text>
          </view>
        </view>
        <view class="time-field">
          <text class="time-label">充电费用</text>
          <view class="input-with-prefix">
            <text class="input-prefix">¥</text>
            <input class="input-field input-with-left-pad" type="digit" placeholder="0.00" value="{{editCost}}" bindinput="onEditCostInput" />
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 充电效率 -->
  <view class="form-group glass-card" wx:if="{{!isEditMode}}">
    <view class="form-label">
      <image class="form-icon-img" src="/assets/icons/line-chart-blue.svg" mode="aspectFit" />
      <text>充电效率</text>
    </view>
    <view class="efficiency-grid">
      <view class="efficiency-item">
        <text class="efficiency-label">充电损耗</text>
        <text class="efficiency-value font-mono" style="color: #22C55E;">{{record.chargeLoss ? record.chargeLoss + '%' : '--'}}</text>
      </view>
      <view class="efficiency-item">
        <text class="efficiency-label">平均功率</text>
        <text class="efficiency-value font-mono">{{record.avgPower ? record.avgPower + ' kW' : '--'}}</text>
      </view>
    </view>
  </view>

  <!-- 里程 -->
  <view class="form-group glass-card" wx:if="{{record.mileage || isEditMode}}">
    <view class="form-label">
      <image class="form-icon-img" src="/assets/icons/mileage-blue.svg" mode="aspectFit" />
      <text>充电完成时仪表盘总里程</text>
      <text class="optional-tag">选填</text>
    </view>
    <view wx:if="{{!isEditMode}}" class="view-field">
      <view class="mileage-box">
        <view class="mileage-item">
          <text class="cost-label">充电完成时总里程</text>
          <text class="font-mono" style="font-weight: 600;">{{record.mileage}} km</text>
        </view>
        <view class="mileage-item" wx:if="{{record.perHundredKwh}}">
          <text class="cost-label">百公里电耗</text>
          <text class="font-mono" style="font-weight: 600; color: #0891B2;">{{record.perHundredKwh}} kWh</text>
        </view>
      </view>
    </view>
    <view wx:else class="edit-field">
      <view class="input-with-suffix">
        <input class="input-field" type="digit" placeholder="输入充电完成时的总里程" value="{{editMileage}}" bindinput="onEditMileageInput" />
        <text class="input-suffix">km</text>
      </view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="form-group glass-card" wx:if="{{record.remark || isEditMode}}">
    <view class="form-label">
      <text class="form-icon">💬</text>
      <text>备注</text>
      <text class="optional-tag">选填</text>
    </view>
    <view wx:if="{{!isEditMode}}" class="view-field">
      <text class="remark-text">{{record.remark}}</text>
    </view>
    <view wx:else class="edit-field">
      <textarea class="textarea-field" placeholder="添加备注信息..." value="{{editRemark}}" bindinput="onEditRemarkInput" />
    </view>
  </view>

  <!-- 编辑/保存按钮 -->
  <view class="action-area">
    <button wx:if="{{!isEditMode}}" class="btn-edit" bindtap="enterEditMode">✏️ 编辑</button>
    <view wx:else class="edit-actions">
      <button class="btn-cancel" bindtap="exitEditMode">取消</button>
      <button class="btn-save" bindtap="saveRecord">✓ 保存修改</button>
    </view>
  </view>

  <!-- 删除 -->
  <view class="delete-area" wx:if="{{!isEditMode}}">
    <text class="delete-btn" bindtap="confirmDelete">🗑 删除记录</text>
  </view>

  <!-- 删除确认 -->
  <delete-confirm
    show="{{showDeleteModal}}"
    message="删除后无法恢复，确定要删除这条充电记录吗？"
    bind:confirm="onDeleteConfirm"
    bind:cancel="onCancelDelete"
  />
</view>
